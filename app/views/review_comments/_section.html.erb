<%= turbo_frame_tag dom_id(review, :comments) do %>
  <div class="rounded-3xl border border-base bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-2xl font-semibold font-['Fraunces']"><%= t("reviews.show.comments.title") %></h2>
      <span class="text-xs font-semibold text-stone-500">
        <%= t("reviews.show.comments.count", count: review_comments.size) %>
      </span>
    </div>

    <% if review_comments.any? %>
      <div class="mt-6 space-y-4">
        <% review_comments.each do |review_comment| %>
          <div class="rounded-2xl border border-base p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <% if review_comment.user.avatar.attached? %>
                  <%= image_tag review_comment.user.avatar.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full object-cover", alt: review_comment.user.username %>
                <% else %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-200 text-xs font-semibold text-stone-600">
                    <%= review_comment.user.username.to_s.first&.upcase || "U" %>
                  </div>
                <% end %>
                <div>
                  <p class="text-sm font-semibold text-stone-800"><%= review_comment.user.username %></p>
                </div>
              </div>
              <% if user_signed_in? && review_comment.user_id == current_user.id %>
                <%= button_to t("reviews.show.comments.delete"),
                  review_review_comment_path(review, review_comment),
                  method: :delete,
                  class: "rounded-full border border-base px-3 py-1 text-xs font-semibold text-stone-600 hover:border-stone-300",
                  form: { data: { turbo_confirm: t("reviews.show.comments.delete_confirm"), loading: "skip" } } %>
              <% end %>
            </div>
            <p class="mt-3 whitespace-pre-wrap text-sm text-stone-700"><%= review_comment.body %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 rounded-2xl border border-dashed border-base bg-stone-50 p-4 text-sm text-stone-500">
        <%= t("reviews.show.comments.empty") %>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <div class="mt-6 border-t border-base pt-6">
        <%= form_with model: [review, review_comment], class: "space-y-3" do |f| %>
          <%= f.label :body, t("reviews.show.comments.form_label"), class: "block text-sm font-semibold text-stone-700" %>
          <%= f.text_area :body, rows: 3, maxlength: 500,
            class: "w-full rounded-2xl border border-base px-4 py-3 text-sm",
            placeholder: t("reviews.show.comments.placeholder") %>
          <% if review_comment.errors[:body].any? %>
            <p class="text-xs font-semibold text-rose-600"><%= review_comment.errors[:body].first %></p>
          <% end %>
          <div class="flex justify-end">
            <%= f.submit t("reviews.show.comments.submit"), class: "btn-primary rounded-full px-5 py-2 text-xs" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
