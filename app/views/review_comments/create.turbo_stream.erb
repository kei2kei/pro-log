<% @review_comments ||= @review.review_comments.includes(user: { avatar_attachment: :blob }).order(created_at: :desc) %>
<% review_comment_for_form = @review_comment.persisted? ? ReviewComment.new : @review_comment %>

<%= turbo_stream.replace dom_id(@review, :comments) do %>
  <%= render "review_comments/section",
    review: @review,
    review_comments: @review_comments,
    review_comment: review_comment_for_form %>
<% end %>

<%= turbo_stream.replace "flash", partial: "shared/flash" %>
