<%= turbo_frame_tag dom_id(product, :bookmark) do %>
  <% if user_signed_in? && bookmark.present? %>
    <%= button_to bookmark_path(bookmark), method: :delete,
      class: "inline-flex w-full items-center justify-center gap-2 rounded-full border border-emerald-500 bg-emerald-50 px-4 py-2 text-xs font-semibold text-emerald-600 hover:border-emerald-600",
      aria: { label: t("shared.bookmark.remove") },
      form: { data: { loading: "skip" } } do %>
      <span class="text-amber-400">★</span>
      <span aria-hidden="true">✓</span>
      <span class="tabular-nums"><%= product.product_bookmarks.size %></span>
    <% end %>
  <% elsif user_signed_in? %>
    <%= button_to bookmarks_path(product_id: product.id), method: :post,
      class: "inline-flex w-full items-center justify-center gap-2 rounded-full border border-stone-200 px-4 py-2 text-xs font-semibold text-stone-600 hover:border-stone-300",
      aria: { label: t("shared.bookmark.add") },
      form: { data: { loading: "skip" } } do %>
      <span class="text-stone-400">☆</span>
      <span class="tabular-nums"><%= product.product_bookmarks.size %></span>
    <% end %>
  <% else %>
    <span class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-stone-200 px-4 py-2 text-xs font-semibold text-stone-500">
      <span aria-hidden="true" class="text-stone-400">☆</span>
      <span class="tabular-nums"><%= product.product_bookmarks.size %></span>
    </span>
  <% end %>
<% end %>
