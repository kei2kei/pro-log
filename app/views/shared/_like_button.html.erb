<%= button_to likes_path(review_id: review.id), method: :post,
  class: "inline-flex items-center gap-2 rounded-full border border-stone-200 px-4 py-2 text-xs font-semibold text-stone-600 hover:border-stone-300",
  aria: { label: t("shared.like.add") },
  form: { data: { loading: "skip" } } do %>
  <span aria-hidden="true" class="text-stone-400">♥</span>
  <span class="tabular-nums"><%= review.review_likes.size %></span>
<% end %>
