<%= button_to like_path(current_user.review_likes.find_by(review_id: review.id)), method: :delete,
  class: "inline-flex items-center gap-2 rounded-full border border-rose-300 bg-rose-50 px-4 py-2 text-xs font-semibold text-rose-600 hover:border-rose-400",
  aria: { label: t("shared.like.saved") },
  form: { data: { loading: "skip" } } do %>
  <span aria-hidden="true" class="text-rose-500">♥</span>
  <span aria-hidden="true">✓</span>
  <span class="tabular-nums"><%= review.review_likes.size %></span>
<% end %>
